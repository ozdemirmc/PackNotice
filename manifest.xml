<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" 
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" 
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides" 
           xsi:type="MailApp">
  <Id>d2c3e1b0-4a6a-4f1a-9f1a-b61b40ba8ba8</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>THY</ProviderName>
  <DefaultLocale>tr-TR</DefaultLocale>
  <DisplayName DefaultValue="Pack Mailler WEB" />
  <Description DefaultValue="Bakım paketleri için otomatik mail hazırlama aracı." />
  <IconUrl DefaultValue="https://ozdemirmc.github.io/PackMaillerWEB/assets/PMTHY.png" />
  <HighResolutionIconUrl DefaultValue="https://ozdemirmc.github.io/PackMaillerWEB/assets/PMTHY.png" />
  <SupportUrl DefaultValue="https://www.turkishairlines.com" />
  <AppDomains>
    <AppDomain>https://ozdemirmc.github.io/PackMaillerWEB</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="Mailbox" />
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://ozdemirmc.github.io/PackMaillerWEB/index.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.1">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgComposeGroup">
                <Label resid="groupLabel" />
                <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                  <Label resid="paneButtonLabel" />
                  <Supertip>
                    <Title resid="paneButtonTitle" />
                    <Description resid="paneButtonDescription" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16" />
                    <bt:Image size="32" resid="icon32" />
                    <bt:Image size="80" resid="icon80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpaneUrl" />
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://ozdemirmc.github.io/PackMaillerWEB/assets/PMTHY.png" />
        <bt:Image id="icon32" DefaultValue="https://ozdemirmc.github.io/PackMaillerWEB/assets/PMTHY.png" />
        <bt:Image id="icon80" DefaultValue="https://ozdemirmc.github.io/PackMaillerWEB/assets/PMTHY.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpaneUrl" DefaultValue="https://ozdemirmc.github.io/PackMaillerWEB/index.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Pack Mailler" />
        <bt:String id="paneButtonLabel" DefaultValue="Pack Mail" />
        <bt:String id="paneButtonTitle" DefaultValue="Pack Mailler'ı Aç" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="paneButtonDescription" DefaultValue="Bakım paketleri için otomatik mail hazırlama aracını açar." />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
